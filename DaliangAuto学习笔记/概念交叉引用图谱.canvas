	"nodes":[
		{"id":"t10000000000001","type":"text","text":"## 📌 核心技术概念交叉引用\n\n每个概念对应它在哪些笔记中被讨论\n点击笔记名可直接跳转","x":621,"y":-1133,"width":350,"height":120,"color":"1"},
